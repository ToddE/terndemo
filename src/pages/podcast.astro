---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

const podcastItems = (await getCollection('news'))
  .filter(item => item.data.category === 'Podcast')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="The TERN Podcast">
  <Header slot="header" />
  
  <section class="bg-brand-blue-light/20 py-24">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <span class="inline-block py-1 px-4 rounded-full bg-brand-magenta/10 text-brand-magenta text-sm font-bold mb-6 uppercase tracking-widest">
        Listen Now
      </span>
      <h1 class="text-5xl font-extrabold mb-6">The TERN Podcast</h1>
      <p class="text-xl text-brand-grey-dark max-w-2xl mx-auto">Conversations on bridging the gap between education and employment.</p>
    </div>
  </section>

  <section class="section-padding">
    {podcastItems.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        {podcastItems.map(item => (
          <a href={`/news-resources/${item.id}`} class="group">
            <div class="glass-card h-full flex overflow-hidden hover:shadow-2xl transition-all duration-300">
              <div class="w-1/3 bg-brand-blue-light/50 overflow-hidden relative flex-shrink-0">
                {item.data.image ? (
                  <img src={item.data.image} alt={item.data.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-brand-magenta text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
                    </svg>
                  </div>
                )}
              </div>
              <div class="p-8 flex-grow flex flex-col justify-center">
                <span class="text-xs text-brand-grey-dark/60 mb-2 uppercase tracking-widest">{item.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                <h3 class="text-xl font-bold mb-4 group-hover:text-brand-magenta transition-colors">{item.data.title}</h3>
                <p class="text-brand-grey-dark text-sm leading-relaxed line-clamp-2 mb-4">{item.data.description}</p>
                <span class="text-brand-magenta font-bold text-sm flex items-center gap-2 group-hover:gap-4 transition-all mt-auto">
                  Listen Episode
                  <span>→</span>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 bg-brand-blue-light/10 rounded-3xl">
        <h3 class="text-2xl font-bold mb-4">No Episodes Yet</h3>
        <p class="text-brand-grey-dark">Check back soon for our first podcast episode!</p>
      </div>
    )}
  </section>

  <Footer slot="footer" />
</Layout>
