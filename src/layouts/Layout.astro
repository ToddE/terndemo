---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Tern Mentoring - Next-Generation Mentoring for the Modern Workforce" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Tern Mentoring</title>
	</head>
	<body class="min-h-screen flex flex-col selection:bg-brand-magenta selection:text-white">
		<slot name="header" />
		<main class="flex-grow">
			<slot />
		</main>
		<slot name="footer" />
	</body>
</html>
