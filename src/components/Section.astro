---
interface Props {
  className?: string;
  id?: string;
  variant?: 'white' | 'light' | 'dark';
}

const { className = '', id, variant = 'white' } = Astro.props;

const variants = {
  white: 'bg-white',
  light: 'bg-brand-blue-light/20',
  dark: 'bg-brand-black text-white'
};
---

<section id={id} class={`py-24 px-6 ${variants[variant]} ${className}`}>
  <div class="max-w-7xl mx-auto">
    <slot />
  </div>
</section>
