{
	"compatibility_date": "2026-04-22",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "tern",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist/client",
		"binding": "ASSETS"
	},
	"route": {
		"pattern": "terndemo.hottoddie.org/*",
		"zone_name": "hottoddie.org"
	},
	"observability": {
		"enabled": true
	}
}